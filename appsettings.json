{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning", // 👈 ضيف السطر ده بالملي
        "Microsoft": "Warning" // 👈 وضيف السطر ده كمان
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/log.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithThreadId"
    ],
    "Properties": {
      "Application": "GraductionProject"
    }
  },
  "AllowedHosts": "*",
  "JWT": {
    "SecretKey": "THIS_IS_SUPER_SECRET_KEY_123456789",
    "Issuer": "MyApp",
    "Audience": "MyAppUsers"
  },
  "ConnectionStrings": {
    "conn": "server=.; database = E-Commercetest3; integrated security = true; trustservercertificate=true"
    //  "conn": "Server=db45590.public.databaseasp.net; Database=db45590; User Id=db45590; Password=5Je@j8?HLt9%; Encrypt=False; MultipleActiveResultSets=True;"
  }



}
